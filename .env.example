# ============================================
# ImobPro - Configurações de Ambiente
# Copie este arquivo para .env e preencha
# ============================================

# Banco de dados (ImobPro) — MongoDB
# Local/docker: mongodb://mongo:27017 | Produção: URI do MongoDB Atlas (mongodb+srv://...)
MONGO_URL=mongodb://mongo:27017
MONGO_DB=imobpro

# Senha do Postgres — usado APENAS pela Evolution API (WhatsApp), não pelo ImobPro
POSTGRES_PASSWORD=SuaSenhaSegura123

# Evolution API (WhatsApp) - roda no proprio docker-compose
# URL interna usada pelo backend (rede docker). Nao mude se rodar tudo junto.
EVOLUTION_API_URL=http://evolution:8080
# URL publica da Evolution (usada por ela p/ webhooks/QR). Ex: http://SEU_IP:8088
EVOLUTION_SERVER_URL=http://localhost:8088
# Chave de autenticacao da Evolution (defina uma forte!)
EVOLUTION_API_KEY=gustavo_imobpro
EVOLUTION_INSTANCE=imobpro

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8001

# Segurança
SECRET_KEY=chave-secreta-aleatoria-aqui
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# E-mail que recebe o link de redefinição de senha do login "admin".
# Se vazio, usa o DONO_PRINCIPAL_EMAIL e, por fim, o SMTP_FROM.
ADMIN_EMAIL=

# Cadastro de novos donos / aprovação por e-mail
# E-mail que RECEBE as solicitações de novos cadastros (aprovar/recusar).
# Se vazio, usa o SMTP_FROM como destinatário.
DONO_PRINCIPAL_EMAIL=
# Conta principal (multi-tenant): dono dos dados legados (alvo da migração) e da
# base semeada (seed). Cada conta só enxerga os próprios dados.
CONTA_PRINCIPAL_EMAIL=nathalial@complexodmc.com.br
# URL pública do frontend — usada para montar o link de redefinição de senha.
# Em produção: https://seu-frontend. Se vazio, usa FRONTEND_ORIGIN.
APP_PUBLIC_URL=

# Busca do "Mapear mercado" - basta UM provedor.
# Google oficial (Custom Search JSON API): 100 buscas/dia gratis, sem cartao.
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
# Alternativas:
SERPER_API_KEY=
BRAVE_API_KEY=

# Hunter.io - acha e-mail corporativo dos decisores pelo dominio da empresa.
# Pegue em https://hunter.io/api-keys (plano gratis: 25 buscas/mes).
HUNTER_API_KEY=

# === Disparo de e-mail ===
# Há dois caminhos. Se você definir uma chave de API HTTP abaixo, ela é usada e o
# SMTP é ignorado. IMPORTANTE: hosts como o Railway (planos Free/Trial/Hobby)
# BLOQUEIAM SMTP de saída — nesses casos use a API HTTP (Resend ou Brevo).
#
# Opção A — API HTTP (porta 443, funciona em qualquer host). Defina UMA chave:
RESEND_API_KEY=
# ou
BREVO_API_KEY=
# Remetente verificado no provedor. Resend exige um DOMÍNIO verificado (ex.:
# lead@suaempresa.com.br); Brevo aceita um remetente único verificado. Se vazio,
# usa o SMTP_FROM. NÃO use um @gmail.com no Resend (precisa ser domínio seu).
EMAIL_FROM=
# Nome exibido no "De:" das campanhas. Se definido, sobrepõe o nome do usuário
# logado (ex.: EMAIL_FROM_NOME=gustavo => "gustavo <lead@suaempresa.com.br>").
EMAIL_FROM_NOME=
#
# Opção B — SMTP (dev local / hosts que permitem SMTP). Porta 465 = SSL; 587 = STARTTLS.
# Ex. Gmail: SMTP_HOST=smtp.gmail.com / SMTP_PORT=587 / use uma "Senha de app".
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NOME=Complexo DMC
SMTP_USE_TLS=true
